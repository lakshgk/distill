{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order",
  "description": "A customer order",
  "type": "object",
  "properties": {
    "orderId": {
      "type": "string",
      "description": "Unique order identifier"
    },
    "quantity": {
      "type": "integer",
      "description": "Number of items"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "shipped",
        "delivered"
      ]
    }
  },
  "required": [
    "orderId",
    "quantity"
  ],
  "$defs": {
    "Address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        }
      }
    }
  }
}