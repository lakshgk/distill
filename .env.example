# ==========================================================================
# Distill — Environment Configuration
# ==========================================================================
#
# Copy this file to .env before running:
#   cp .env.example .env
#
# .env is gitignored — never commit it to version control.
#
# Variables left empty disable the corresponding feature gracefully.
# The system will fall back to synchronous processing and skip optional
# features (LLM, vision, Google Workspace, audio diarization) when their
# credentials are not configured.
#
# For the full reference with defaults and feature matrix, see:
#   docs/configuration.md
# ==========================================================================


# ---------------------------------------------------------------------------
# Infrastructure — required for all deployments
# ---------------------------------------------------------------------------

# Redis connection URL (used by API server, Celery worker, and job store)
REDIS_URL=redis://redis:6379/0

# Files larger than this threshold (MB) are processed asynchronously via Celery
DISTILL_ASYNC_SIZE_THRESHOLD_MB=10

# How long (seconds) job results are kept in Redis before expiring
DISTILL_JOB_TTL_SECONDS=3600

# Number of concurrent Celery worker processes per container
DISTILL_WORKER_CONCURRENCY=4

# Concurrency for the interactive worker pool (human-waiting jobs)
DISTILL_INTERACTIVE_CONCURRENCY=4

# Concurrency for the batch worker pool (background/large jobs)
DISTILL_BATCH_CONCURRENCY=2


# ---------------------------------------------------------------------------
# LLM features — optional
# Enables: cross-page table merging, structured JSON extraction,
#          audio topic segmentation
# Per-request llm_api_key form field values take precedence over these defaults
# ---------------------------------------------------------------------------

# API key for any OpenAI-compatible endpoint
DISTILL_LLM_API_KEY=

# Model identifier (e.g. gpt-4o, claude-3-5-sonnet, mistral-small)
DISTILL_LLM_MODEL=

# Base URL for the LLM endpoint (e.g. https://api.openai.com/v1)
# Leave empty to require callers to supply base_url per request
DISTILL_LLM_BASE_URL=


# ---------------------------------------------------------------------------
# Vision / image captioning — optional
# Enables: AI-generated image descriptions when images="caption"
# ---------------------------------------------------------------------------

# Vision backend: openai, anthropic, or ollama
DISTILL_VISION_PROVIDER=

# API key for the vision provider (not needed for ollama)
DISTILL_VISION_API_KEY=

# Base URL for ollama or custom vision endpoint
DISTILL_VISION_BASE_URL=


# ---------------------------------------------------------------------------
# Google Workspace — optional
# Enables: Google Docs, Sheets, Slides input via Drive URL
# Two auth methods (mutually exclusive):
#   1. Per-request OAuth2 token (caller passes access_token in API request)
#   2. Service account JSON key file (set path below)
# ---------------------------------------------------------------------------

# Server-side default OAuth2 token (per-request tokens take precedence)
DISTILL_GOOGLE_ACCESS_TOKEN=

# Path to a Google service account JSON key file
DISTILL_GOOGLE_CREDENTIALS_PATH=


# ---------------------------------------------------------------------------
# Audio pipeline — optional
# Enables: speaker diarization in audio transcription
# Requires: pip install distill-core[audio]
#
# To obtain a Hugging Face token:
#   1. Create a free account at https://huggingface.co
#   2. Accept the model licence at:
#      https://huggingface.co/pyannote/speaker-diarization-3.1
#   3. Generate a token at https://huggingface.co/settings/tokens
#   4. Paste it below
#
# If left empty, speaker diarization is skipped — transcription still works
# ---------------------------------------------------------------------------

# Hugging Face access token for pyannote speaker diarization model
DISTILL_HF_TOKEN=


# ---------------------------------------------------------------------------
# Webhook delivery — async job callback notifications
# ---------------------------------------------------------------------------

# Timeout (seconds) for each webhook delivery attempt
DISTILL_WEBHOOK_TIMEOUT_SECONDS=10


# ---------------------------------------------------------------------------
# SSE progress streaming — job progress event streaming
# ---------------------------------------------------------------------------

# Seconds between heartbeat comments (keeps proxies alive)
DISTILL_SSE_KEEPALIVE_SECONDS=15

# Maximum duration (seconds) for an SSE stream before auto-closing
DISTILL_SSE_MAX_DURATION_SECONDS=3600
